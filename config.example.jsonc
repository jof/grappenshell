{
  // Tailscale hostname for the tsnet node
  "hostname": "grappenshell",

  // Simulated shell identity
  "sim_hostname": "grappenshell",
  "default_user": "user",
  "default_home": "/home/user",

  // OpenAI-compatible API base URL (can be on the tailnet)
  "llm_url": "http://localhost:11434/v1",

  // Model name
  "llm_model": "llama3",

  // SSH listen port on the tsnet node
  "ssh_port": 2222,

  // System prompt — the secret sauce. Current shell state (CWD, user, env) is
  // injected automatically each turn. Use EITHER system_prompt_file (recommended
  // for longer prompts) OR inline system_prompt.
  //
  // "system_prompt_file": "system-prompt.txt",
  "system_prompt": "You are simulating a realistic Linux terminal. Respond ONLY with raw terminal output. No markdown, no backticks, no explanations. Be creative with file contents and system state."
}
